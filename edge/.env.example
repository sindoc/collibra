# .env.example — copy to .env and fill in values before running docker compose

# ── Required ──────────────────────────────────────────────────────────────────
COLLIBRA_EDGE_HOSTNAME=edge.example.com
COLLIBRA_DGC_URL=https://your-dgc-instance.collibra.com

# ── Edge Site ─────────────────────────────────────────────────────────────────
# Obtain SITE_ID and REG_KEY from: Collibra DGC → Settings → Edge → Sites → Add Site
COLLIBRA_EDGE_SITE_ID=edge-site-prod-01
COLLIBRA_EDGE_SITE_NAME=Production Edge Site
COLLIBRA_EDGE_REG_KEY=your-registration-key-from-dgc

# Comma-separated capabilities to activate: connect,catalog,lineage,profiling,site,workflow
EDGE_SITE_CAPABILITIES=site,connect,catalog
