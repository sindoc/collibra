<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IRIB3 — شبکه سه</title>
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest/dist/hls.min.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0a0a0a;
      color: #e8e8e8;
      font-family: system-ui, -apple-system, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
      padding: 1.5rem;
    }

    header {
      width: 100%;
      max-width: 960px;
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .badge {
      background: #c0392b;
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      padding: 0.2rem 0.55rem;
      border-radius: 3px;
      text-transform: uppercase;
    }

    h1 {
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .status {
      margin-right: auto;
      font-size: 0.78rem;
      color: #888;
    }

    .player-wrap {
      width: 100%;
      max-width: 960px;
      background: #111;
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 4px 32px rgba(0,0,0,0.6);
      position: relative;
    }

    video {
      width: 100%;
      display: block;
      aspect-ratio: 16/9;
      background: #000;
    }

    .controls {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
      background: #161616;
      border-top: 1px solid #222;
    }

    button {
      background: #222;
      border: 1px solid #333;
      color: #e8e8e8;
      padding: 0.35rem 0.9rem;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.82rem;
      transition: background 0.15s;
    }
    button:hover { background: #2e2e2e; }
    button.active { background: #c0392b; border-color: #c0392b; }

    .quality-label {
      font-size: 0.78rem;
      color: #666;
      margin-right: auto;
    }

    .error-box {
      display: none;
      width: 100%;
      max-width: 960px;
      margin-top: 1rem;
      padding: 0.85rem 1.1rem;
      background: #1a0a0a;
      border: 1px solid #5a1a1a;
      border-radius: 5px;
      font-size: 0.82rem;
      color: #e07070;
      line-height: 1.5;
    }

    footer {
      margin-top: 1.5rem;
      font-size: 0.72rem;
      color: #444;
    }
  </style>
</head>
<body>

<header>
  <span class="badge">زنده</span>
  <h1>شبکه سه — IRIB3</h1>
  <span class="status" id="status">در حال اتصال...</span>
</header>

<div class="player-wrap">
  <video id="video" controls playsinline></video>
  <div class="controls">
    <button id="btn-play" class="active" onclick="togglePlay()">▶ پخش</button>
    <button onclick="document.getElementById('video').muted = !document.getElementById('video').muted; this.textContent = document.getElementById('video').muted ? '🔇 بی‌صدا' : '🔊 صدا'">🔊 صدا</button>
    <button onclick="document.getElementById('video').requestFullscreen && document.getElementById('video').requestFullscreen()">⛶ تمام صفحه</button>
    <span class="quality-label" id="quality">—</span>
  </div>
</div>

<div class="error-box" id="error-box"></div>

<footer>پخش زنده از طریق CDN داخلی | <span id="cdn-host"></span></footer>

<script>
  const STREAM = '${IRIB3_STREAM_PATH}';   // proxied via nginx → lenz.splus.ir

  const video   = document.getElementById('video');
  const status  = document.getElementById('status');
  const errBox  = document.getElementById('error-box');
  const quality = document.getElementById('quality');

  document.getElementById('cdn-host').textContent = location.host;

  function togglePlay() {
    video.paused ? video.play() : video.pause();
  }

  video.addEventListener('playing', () => {
    status.textContent = '● پخش زنده';
    status.style.color = '#27ae60';
    document.getElementById('btn-play').textContent = '⏸ توقف';
  });
  video.addEventListener('pause', () => {
    status.textContent = 'متوقف';
    status.style.color = '#888';
    document.getElementById('btn-play').textContent = '▶ پخش';
  });
  video.addEventListener('waiting', () => {
    status.textContent = 'بارگذاری...';
    status.style.color = '#e6a817';
  });

  function showError(msg) {
    errBox.style.display = 'block';
    errBox.textContent = msg;
    status.textContent = 'خطا';
    status.style.color = '#e07070';
  }

  if (Hls.isSupported()) {
    const hls = new Hls({
      liveSyncDurationCount: 3,
      liveMaxLatencyDurationCount: 6,
      enableWorker: true,
      lowLatencyMode: false,
    });

    hls.loadSource(STREAM);
    hls.attachMedia(video);

    hls.on(Hls.Events.MANIFEST_PARSED, (_, data) => {
      const levels = data.levels;
      if (levels.length) {
        quality.textContent = `${levels[levels.length - 1].height || ''}p`;
      }
      video.play().catch(() => {});
    });

    hls.on(Hls.Events.LEVEL_SWITCHED, (_, data) => {
      const lvl = hls.levels[data.level];
      quality.textContent = lvl ? `${lvl.height || '?'}p` : '—';
    });

    hls.on(Hls.Events.ERROR, (_, data) => {
      if (data.fatal) {
        switch (data.type) {
          case Hls.ErrorTypes.NETWORK_ERROR:
            showError('خطای شبکه: جریان در دسترس نیست. چند ثانیه دیگر تلاش مجدد...');
            setTimeout(() => hls.startLoad(), 5000);
            break;
          case Hls.ErrorTypes.MEDIA_ERROR:
            showError('خطای رسانه. تلاش برای بازیابی...');
            hls.recoverMediaError();
            break;
          default:
            showError('خطای غیرقابل بازیابی: ' + data.details);
            hls.destroy();
        }
      }
    });

  } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
    // Safari native HLS
    video.src = STREAM;
    video.addEventListener('loadedmetadata', () => video.play().catch(() => {}));
    video.addEventListener('error', () => showError('خطا در پخش: ' + (video.error?.message || 'نامشخص')));
  } else {
    showError('مرورگر شما از پخش HLS پشتیبانی نمی‌کند. لطفاً از Chrome یا Firefox استفاده کنید.');
  }
</script>

</body>
</html>
