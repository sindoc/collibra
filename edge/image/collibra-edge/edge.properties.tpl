# Collibra Edge Node Properties
# Generated at container startup by entrypoint.sh — do not edit manually.
# Template tokens: {{HOSTNAME}}, {{DGC_URL}}, {{HTTP_PORT}}, {{HTTPS_PORT}}

collibra.edge.hostname={{HOSTNAME}}
collibra.dgc.url={{DGC_URL}}
collibra.edge.http.port={{HTTP_PORT}}
collibra.edge.https.port={{HTTPS_PORT}}

# Java runtime
java.home=/usr/lib/jvm/jre-11-openjdk

# Collibra catalog governance reference (collibraId populated via Collibra catalog)
# collibraId=
